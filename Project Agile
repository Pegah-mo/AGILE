        public bool ChangeStoryState(int storyId, StoryState newState)
        {
            UserStory story = myDataService.GetStoryById(storyId);
            if (story == null)
            {
                Console.WriteLine("Error: User story not found!");
                return false;
            }

            if (story.State == StoryState.ProjectBacklog && newState == StoryState.Done)
            {
                Console.WriteLine("Error: Cannot move directly from ProjectBacklog to Done!");
                return false;
            }

            if (story.State == StoryState.InSprint && newState == StoryState.Done)
            {
                List<Task> tasks = myDataService.GetTasksByStory(storyId);
                foreach (Task t in tasks)
                {
                    if (t.State != TaskState.Done)
                    {
                        Console.WriteLine("Error: All tasks must be Done first!");
                        return false;
                    }
                }
            }

            myDataService.UpdateStoryState(storyId, newState);
            return true;
        }

